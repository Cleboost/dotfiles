#!/usr/bin/env bash

for file in ~/.local/share/applications/jetbrains-*.desktop; do
    [ -f "$file" ] || continue

    sed -i \
      -e 's|^Icon=.*webstorm.*|Icon=jetbrains-webstorm|' \
      -e 's|^Icon=.*rustrover.*|Icon=jetbrains-rustrover|' \
      -e 's|^Icon=.*clion.*|Icon=jetbrains-clion|' \
      -e 's|^Icon=.*idea.*|Icon=jetbrains-intellij-idea|' \
      -e 's|^Icon=.*studio.*|Icon=android-studio|' \
      "$file"
done

update-desktop-database ~/.local/share/applications >/dev/null 2>&1
