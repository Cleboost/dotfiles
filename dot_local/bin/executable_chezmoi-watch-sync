#!/usr/bin/env bash
set -u

CONFIG_FILE="$HOME/.config/chezmoi-watch/paths"

mapfile -t paths < <(
  grep -vE "^[[:space:]]*($|#)" "$CONFIG_FILE" | while read -r path; do
    expanded="${path/#\~/$HOME}"
    [ -e "$expanded" ] && printf "%s\n" "$expanded"
  done
)

[ "${#paths[@]}" -eq 0 ] && exit 0

chezmoi re-add "${paths[@]}"