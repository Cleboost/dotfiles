#!/usr/bin/env bash
set -u

CONFIG_FILE="$HOME/.config/chezmoi-watch/paths"

files=()
dirs=()

while read -r path; do
  expanded="${path/#\~/$HOME}"

  if [ -f "$expanded" ]; then
    files+=("$expanded")
  elif [ -d "$expanded" ]; then
    dirs+=("$expanded")
  fi
done < <(grep -vE "^[[:space:]]*($|#)" "$CONFIG_FILE")

[ "${#files[@]}" -eq 0 ] && [ "${#dirs[@]}" -eq 0 ] && {
  notify-send "chezmoi" "Aucun chemin valide à synchroniser."
  exit 0
}

notify-send "chezmoi" "Synchronisation en cours..."

repo="$(chezmoi source-path)"
before="$(git -C "$repo" rev-parse HEAD 2>/dev/null || true)"

if [ "${#files[@]}" -gt 0 ]; then
  chezmoi re-add "${files[@]}" || {
    notify-send "chezmoi" "Erreur pendant la synchronisation des fichiers."
    exit 1
  }
fi

changed_in_dirs=()

if [ "${#dirs[@]}" -gt 0 ]; then
  for dir in "${dirs[@]}"; do
    while IFS= read -r file; do
      [ -f "$file" ] && changed_in_dirs+=("$file")
    done < <(
      find "$dir" -type f -newer "$repo/.git/index" 2>/dev/null
    )
  done

  if [ "${#changed_in_dirs[@]}" -gt 0 ]; then
    chezmoi add "${changed_in_dirs[@]}" || {
      notify-send "chezmoi" "Erreur pendant la synchronisation des dossiers."
      exit 1
    }
  fi
fi

after="$(git -C "$repo" rev-parse HEAD 2>/dev/null || true)"

if [ "$before" != "$after" ]; then
  notify-send "chezmoi" "Modifications synchronisées et push."
else
  notify-send "chezmoi" "Aucun changement à synchroniser."
fi