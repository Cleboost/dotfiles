#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="$HOME/.config/chezmoi-watch/paths"
COMMIT_MESSAGE="auto: sync watched config files"
DEBOUNCE_SECONDS=5

if ! command -v inotifywait >/dev/null 2>&1; then
  notify-send "chezmoi watch" "inotifywait introuvable. Installe inotify-tools."
  exit 1
fi

if ! command -v chezmoi >/dev/null 2>&1; then
  notify-send "chezmoi watch" "chezmoi introuvable."
  exit 1
fi

if [ ! -f "$CONFIG_FILE" ]; then
  notify-send "chezmoi watch" "Config introuvable: $CONFIG_FILE"
  exit 1
fi

read_paths() {
  grep -vE "^\s*($|#)" "$CONFIG_FILE" | while read -r path; do
    expanded="${path/#\~/$HOME}"
    [ -e "$expanded" ] && printf "%s\n" "$expanded"
  done
}

sync_now() {
  mapfile -t paths < <(read_paths)
  [ "${#paths[@]}" -eq 0 ] && return 0

  chezmoi re-add "${paths[@]}"

  chezmoi cd >/dev/null
  git add .

  if git diff --cached --quiet; then
    return 0
  fi

  git commit -m "$COMMIT_MESSAGE"
  git push

  notify-send "chezmoi" "Config synchronisée sur GitHub."
}

while true; do
  mapfile -t paths < <(read_paths)

  if [ "${#paths[@]}" -eq 0 ]; then
    sleep 30
    continue
  fi

  inotifywait -r -e modify,create,delete,move "${paths[@]}" >/dev/null 2>&1 || true
  sleep "$DEBOUNCE_SECONDS"
  sync_now || notify-send "chezmoi" "Erreur pendant la synchronisation."
done
