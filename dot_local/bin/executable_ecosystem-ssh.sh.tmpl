#!/usr/bin/env bash
export SSH_AUTH_SOCK="${SSH_AUTH_SOCK:-$HOME/.bitwarden-ssh-agent.sock}"

# This script is auto-generated by chezmoi. Do not edit manually.

# Ecosystem PCs mapping
declare -A pcs
{{ range $name, $info := .pcs -}}
pcs["{{ $name }}"]="{{ $info.ip }}"
{{ end }}

# Exclude the current host
current_hostname="{{ .chezmoi.hostname }}"

# Prepare list for fzf
menu_list=""
for name in "${!pcs[@]}"; do
    if [ "$name" != "$current_hostname" ]; then
        menu_list="$menu_list$name (${pcs[$name]})\n"
    fi
done

if [ -z "$menu_list" ]; then
    echo "No other ecosystem PCs found in configuration."
    sleep 3
    exit 0
fi

# Show fzf menu
selected=$(echo -e -n "$menu_list" | fzf \
  --prompt="🖥️  Connect to Ecosystem PC: " \
  --height=100% \
  --layout=reverse \
  --border=rounded \
  --margin=1 \
  --padding=1 \
  --color="bg+:-1,fg+:2,prompt:5,border:4" \
  --header="Press ESC to exit")

if [ -n "$selected" ]; then
    # Extract IP address from inside parentheses
    target_ip=$(echo "$selected" | sed -n 's/.*(\(.*\))/\1/p')
    target_name=$(echo "$selected" | awk '{print $1}')
    
    # Disable floating mode if the window is currently floating
    if command -v hyprctl >/dev/null 2>&1 && hyprctl activewindow | grep -q "floating: 1"; then
        hyprctl dispatch 'hl.dsp.window.float({ action = "toggle" })'
    fi

    clear
    echo "🔌 Connecting SSH to $target_name ($target_ip)..."
    ssh -t "$target_ip" "clear; exec \$SHELL"
    
    if [ $? -ne 0 ]; then
        echo -e "\n❌ Connection error to $target_name. Closing in 5 seconds..."
        sleep 5
    fi
fi
