#!/usr/bin/env bash

# Exit immediately if a command exits with a non-zero status
set -e

# Check if we are inside a git repository
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "❌ Error: Not a git repository." >&2
    exit 1
fi

# Check if there are any changes (staged, unstaged, or untracked)
if [ -z "$(git status --porcelain)" ]; then
    echo "ℹ️ No changes detected to commit."
    exit 0
fi

# Prompt instructing the agent on what to do
PROMPT="Examine the current git status and diff. Group the changes into one or more coherent logical themes, and create one or more conventional commits (e.g. feat:, fix:, chore:, refactor:) to commit them. Do not push the commits."

echo "🤖 Launching Kilo agent to commit changes..."
exec kilo run "$PROMPT" "$@"
