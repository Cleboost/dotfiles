#!/usr/bin/env bash

profile="$(powerprofilesctl get 2>/dev/null | tr "[:upper:]" "[:lower:]")"

case "$profile" in
  power-saver|quiet|silent|silencieux)
    color="00ff00"
    ;;
  balanced|balance|balanced-performance)
    color="0000ff"
    ;;
  performance|turbo)
    color="ff0000"
    ;;
  *)
    color="ffffff"
    ;;
esac

asusctl aura effect static --colour "$color"
