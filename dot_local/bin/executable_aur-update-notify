#!/usr/bin/env bash

repo_updates="$(checkupdates 2>/dev/null)"
aur_updates="$(yay -Qua 2>/dev/null)"

updates="$(printf "%s\n%s\n" "$repo_updates" "$aur_updates" | sed "/^$/d")"
[ -z "$updates" ] && exit 0

count="$(printf "%s\n" "$updates" | wc -l)"

notify-send "Mises à jour disponibles" "$count paquet(s) à mettre à jour

$updates"
