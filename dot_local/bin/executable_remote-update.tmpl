#!/usr/bin/env bash
export SSH_AUTH_SOCK="${SSH_AUTH_SOCK:-$HOME/.bitwarden-ssh-agent.sock}"

# This script is auto-generated by chezmoi. Do not edit manually.

# Ecosystem PCs mapping
declare -A pcs
{{ range $name, $info := .pcs -}}
pcs["{{ $name }}"]="{{ $info.ip }}"
{{ end }}

current_hostname="{{ .chezmoi.hostname }}"

# Prepare list for fzf
menu_list="✨ All PCs\n"
for name in "${!pcs[@]}"; do
    if [ "$name" != "$current_hostname" ]; then
        menu_list="$menu_list$name (${pcs[$name]})\n"
    fi
done

# Show fzf menu
selected=$(echo -e -n "$menu_list" | fzf \
  --prompt="🔄 Select PC to Update: " \
  --height=100% \
  --layout=reverse \
  --border=rounded \
  --margin=1 \
  --padding=1 \
  --color="bg+:-1,fg+:2,prompt:5,border:4" \
  --header="Press ESC to exit")

if [ -z "$selected" ]; then
    exit 0
fi

# Function to update a single PC
update_pc() {
    local name="$1"
    local ip="$2"
    
    echo "============================================="
    echo "🔄 Updating $name ($ip)..."
    echo "============================================="
    
    if [ "$name" = "$current_hostname" ]; then
        # Run update locally
        fish -i -c "update"
    else
        # Run update remotely via SSH
        ssh -t "$ip" "fish -i -c update"
    fi
    
    if [ $? -eq 0 ]; then
        echo "✅ Success updating $name"
    else
        echo "❌ Failed updating $name"
    fi
    echo ""
}

if [ "$selected" = "✨ All PCs" ]; then
    # Always update cleboost-brain first to compile latest versions and populate the cache
    brain_ip="${pcs["cleboost-brain"]}"
    if [ -n "$brain_ip" ]; then
        update_pc "cleboost-brain" "$brain_ip"
    fi
    
    # Then update all other PCs
    for name in "${!pcs[@]}"; do
        if [ "$name" != "cleboost-brain" ]; then
            update_pc "$name" "${pcs[$name]}"
        fi
    done
else
    # Extract name and IP from selection
    target_name=$(echo "$selected" | awk '{print $1}')
    target_ip=$(echo "$selected" | sed -n 's/.*(\(.*\))/\1/p')
    # strip "[Local]" if present
    target_ip=$(echo "$target_ip" | sed 's/ \[Local\]//')
    
    update_pc "$target_name" "$target_ip"
fi

echo "Press ENTER to exit..."
read -r
