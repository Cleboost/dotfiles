#!/bin/bash
{{ if ne .chezmoi.os "linux" -}}
exit 0
{{ end -}}

set -eu

if ! command -v yay >/dev/null 2>&1; then
  sudo pacman -Sy --needed --noconfirm base-devel git

  tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' EXIT

  git clone https://aur.archlinux.org/yay.git "$tmpdir/yay"
  cd "$tmpdir/yay"
  makepkg -si --noconfirm
  cd /
fi

if ! command -v yay >/dev/null 2>&1; then
  echo "yay n'a pas pu être installé"
  exit 1
fi

{{- $categories := list "base" -}}
{{- if hasKey .pcs .chezmoi.hostname -}}
  {{- $categories = concat $categories (index .pcs .chezmoi.hostname).packages -}}
{{- end -}}

{{- $yay := list -}}
{{- range $categories -}}
  {{- if hasKey $.categories.arch.yay . -}}
    {{- range (index $.categories.arch.yay .) -}}
      {{- $yay = append $yay . -}}
    {{- end -}}
  {{- end -}}
{{- end -}}


{{- if $yay }}
echo "=================================================="
echo "    Synchronizing Arch Linux packages with yay    "
echo "=================================================="

packages_all="{{ join " " (uniq (sortAlpha $yay)) }}"
total_packages=$(echo "$packages_all" | wc -w)
up_to_date_count=0
new_install_count=0
exit_code=0

# Run yay in non-interactive mode and parse its output in real-time
while IFS= read -r line; do
  case "$line" in
    EXIT_CODE=*)
      exit_code="${line#EXIT_CODE=}"
      continue
      ;;
  esac

  if echo "$line" | grep -E -q "est à jour -- ignoré|is up to date -- ignoring|is up to date -- skipping|avertissement : .* est à jour|warning: .* is up to date"; then
    up_to_date_count=$((up_to_date_count + 1))
  elif echo "$line" | grep -E -q "il n’y a rien à faire|there is nothing to do|Sync Explicit|Sync Dependency"; then
    # Silence these lines completely
    :
  else
    # Check if it represents an installation or update action
    if echo "$line" | grep -E -q "Installing|Upgrading|Installation de|Mise à jour de"; then
      new_install_count=$((new_install_count + 1))
    fi
    echo "  $line"
  fi
done < <(yay -S --needed --noconfirm --devel $packages_all 2>&1; echo "EXIT_CODE=$?")

if [ "$exit_code" -ne 0 ]; then
  echo ""
  echo "Automatic installation failed (probable conflict or auth issue)."
  echo "Retrying in interactive mode to let you resolve conflicts..."
  echo ""
  if ! yay -S --needed --devel $packages_all; then
    echo "Interactive installation failed."
    exit "$exit_code"
  fi
  # If interactive succeeds, we set exit_code to 0
  exit_code=0
  new_install_count=$((total_packages - up_to_date_count))
fi

echo "=================================================="
echo "        Arch Linux Package Sync Completed         "
echo "=================================================="
echo "  Total packages configured: $total_packages"
echo "  Already up-to-date:        $up_to_date_count"
echo "  Newly installed/updated:   $new_install_count"
echo "=================================================="
if [ "$exit_code" -eq 0 ]; then
  echo "  Status:                    All packages up-to-date."
else
  echo "  Status:                    Failed (Exit code: $exit_code)"
fi
echo "=================================================="
{{- end }}

{{- $bun := list -}}
{{- if hasKey .categories "bun" -}}
  {{- $bun = .categories.bun.global.cli -}}
{{- end -}}

{{- if $bun }}
if command -v bun >/dev/null 2>&1; then
  bun add -g {{ join " " (uniq $bun) }}
else
  echo "bun n'est pas installé, installation des paquets globaux bun ignorée"
fi
{{- end }}